{
  "name": "@cristiadu/vavalm-api",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vavalm/vavalm.git"
  },
  "scripts": {
    "postinstall": "pnpm generate:spec && pnpm generate:routes && pnpm generate:client",
    "dev": "npm-run-all --parallel watch server",
    "watch": "webpack --watch --config webpack.config.js --mode development",
    "server": "nodemon --watch dist/bundle.js dist/bundle.js",
    "dev:built": "npm-run-all --parallel build start",
    "create-env-file": "cp .env.template .env",
    "build": "NODE_ENV=production pnpm generate:routes && pnpm generate:client && pnpm webpack --config webpack.config.js --mode production",
    "start": "wait-on dist/bundle.js && node --max-old-space-size=4096 dist/bundle.js",
    "test": "vitest run",
    "check-health": "wait-on -t 60000 http://localhost:8000/api/health",
    "test:coverage": "vitest run --coverage",
    "lint": "pnpm eslint . --config  ./eslint.config.js",
    "lint:fix": "pnpm eslint . --config  ./eslint.config.js --fix",
    "clean": "rm -rf node_modules && rm -rf dist && rm -rf .turbo && rm -rf tests/coverage",
    "migrate": "cd src && pnpm sequelize-cli db:migrate",
    "upgrade:dependencies": "pnpm upgrade --latest",
    "generate:spec": "pnpm tsoa spec",
    "generate:routes": "pnpm tsoa routes",
    "generate:client": "pnpm openapi --input ./docs/openapi.yaml --output ./tests/generated/api --client fetch --name VavalMApi --indent 2"
  },
  "dependencies": {
    "body-parser": "^2.2.2",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "sequelize": "^6.37.8",
    "sequelize-cli": "^6.6.5",
    "swagger-ui-express": "^5.0.1",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/js": "^10.0.1",
    "@tsoa/runtime": "7.0.0-alpha.0",
    "@types/body-parser": "^1.19.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.2",
    "babel-loader": "^10.1.1",
    "domhandler": "^6.0.1",
    "dotenv": "^17.4.0",
    "eslint": "^10.1.0",
    "eslint-plugin-n": "^17.24.0",
    "globals": "^17.4.0",
    "nodemon": "^3.1.14",
    "npm-run-all": "^4.1.5",
    "openapi-typescript-codegen": "^0.30.0",
    "ts-loader": "^9.5.4",
    "tsoa": "7.0.0-alpha.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2",
    "wait-on": "^9.0.4",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2",
    "worker-plugin": "^5.0.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
